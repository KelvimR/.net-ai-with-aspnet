{
  "openapi": "3.1.1",
  "info": {
    "title": ".NET AI API",
    "description": "Essa API prove funcionalidades como chat, geracao de imagens... ",
    "termsOfService": "https://www.linkedin.com/in/kelvim-rodrigues-dev/",
    "contact": {
      "name": "Kelvim Rodrigues",
      "url": "https://www.linkedin.com/in/kelvim-rodrigues-dev/",
